# --- ML model paths (Module 5) ---
SENTIMENT_MODEL_PATH=ml/best_sentiment_model.pkl
TFIDF_VECTORIZER_PATH=ml/tfidf_vectorizer.pkl
LABEL_ENCODER_PATH=ml/label_encoder.pkl

# --- LLM / AI draft service (Module 6) ---
ANTHROPIC_API_KEY=

# --- Email service (Module 7) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@genreview.ai
