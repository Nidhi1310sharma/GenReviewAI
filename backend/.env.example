# Copy this file to .env and fill in real values. Never commit the real .env.

# --- App ---
APP_NAME=GenReview AI
APP_ENV=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# --- CORS (comma-separated origins the frontend is served from) ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://genreview_user:genreview_pass@localhost:5432/genreview_db

#--- Supabase SDK Credentials ---
